@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold text-primary">Fast Print Termocolantes</h1>
    <p class="lead text-muted mt-3">Impressão de qualidade para o seu negócio.</p>
    <a asp-controller="Pedidos" asp-action="Solicitar" class="btn btn-primary btn-lg mt-3">Solicitar Pedido</a>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Serviços</h5>
                <p class="card-text text-muted">Impressão em termocolantes, etiquetas e materiais personalizados.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Agilidade</h5>
                <p class="card-text text-muted">Receba seu pedido com rapidez e acompanhamento dedicado.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Atendimento</h5>
                <p class="card-text text-muted">Equipe pronta para ajudar em cada etapa do seu pedido.</p>
            </div>
        </div>
    </div>
</div>
