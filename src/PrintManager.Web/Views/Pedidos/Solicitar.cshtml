@model SolicitarPedidoViewModel
@{
    ViewData["Title"] = "Solicitar Pedido";
}

<h2 class="mb-4">Solicitar Pedido</h2>

<form asp-action="Solicitar" method="post" enctype="multipart/form-data" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="NomeCliente" class="form-label"></label>
        <input asp-for="NomeCliente" class="form-control" />
        <span asp-validation-for="NomeCliente" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Telefone" class="form-label"></label>
        <input asp-for="Telefone" class="form-control" placeholder="(00) 00000-0000" />
        <span asp-validation-for="Telefone" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="DescricaoServico" class="form-label"></label>
        <textarea asp-for="DescricaoServico" class="form-control" rows="4"></textarea>
        <span asp-validation-for="DescricaoServico" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Quantidade" class="form-label"></label>
        <input asp-for="Quantidade" class="form-control" type="number" min="1" />
        <span asp-validation-for="Quantidade" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Arquivos" class="form-label"></label>
        <input asp-for="Arquivos" class="form-control" type="file" multiple />
        <div class="form-text">Você pode enviar múltiplos arquivos.</div>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Enviar Pedido</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
