@model IReadOnlyList<PedidoListagemDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pedidos";
    var filtro = ViewBag.Filtro as PedidoFiltroViewModel ?? new PedidoFiltroViewModel();
}

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="Status" class="form-select">
            <option value="">Todos</option>
            @foreach (StatusPedido status in Enum.GetValues<StatusPedido>())
            {
                if (filtro.Status == status)
                {
                    <option value="@((int)status)" selected>@StatusPedidoHelper.ObterDescricao(status)</option>
                }
                else
                {
                    <option value="@((int)status)">@StatusPedidoHelper.ObterDescricao(status)</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Período Inicial</label>
        <input type="date" name="PeriodoInicial" class="form-control" value="@filtro.PeriodoInicial?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Período Final</label>
        <input type="date" name="PeriodoFinal" class="form-control" value="@filtro.PeriodoFinal?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Filtrar</button>
        <a asp-controller="AdminPedidos" asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Cliente</th>
                <th>Telefone</th>
                <th>Status</th>
                <th>Data Criação</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Nenhum pedido encontrado.</td>
                </tr>
            }
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>@pedido.NomeCliente</td>
                    <td>@pedido.Telefone</td>
                    <td>
                        <span class="badge @StatusPedidoHelper.ObterBadgeClass(pedido.Status)">
                            @StatusPedidoHelper.ObterDescricao(pedido.Status)
                        </span>
                    </td>
                    <td>@pedido.DataCriacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-controller="AdminPedidos" asp-action="Detalhes" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-primary">Detalhes</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
