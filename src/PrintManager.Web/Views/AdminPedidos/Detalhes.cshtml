@model PedidoDetalheViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Detalhes do Pedido";
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Dados do Cliente</h5>
                <a href="@Model.WhatsAppUrl" target="_blank" rel="noopener" class="btn btn-success btn-sm">
                    Conversar no WhatsApp
                </a>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Model.NomeCliente</dd>

                    <dt class="col-sm-4">Telefone</dt>
                    <dd class="col-sm-8">@Model.Telefone</dd>

                    <dt class="col-sm-4">Descrição</dt>
                    <dd class="col-sm-8">@Model.DescricaoServico</dd>

                    <dt class="col-sm-4">Quantidade</dt>
                    <dd class="col-sm-8">@Model.Quantidade</dd>

                    <dt class="col-sm-4">Valor Pago</dt>
                    <dd class="col-sm-8">@(Model.ValorPago?.ToString("C") ?? "-")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @StatusPedidoHelper.ObterBadgeClass(Model.Status)">
                            @StatusPedidoHelper.ObterDescricao(Model.Status)
                        </span>
                    </dd>

                    <dt class="col-sm-4">Data Criação</dt>
                    <dd class="col-sm-8">@Model.DataCriacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (Model.DataFinalizacao.HasValue)
                    {
                        <dt class="col-sm-4">Data Finalização</dt>
                        <dd class="col-sm-8">@Model.DataFinalizacao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ObservacaoInterna))
                    {
                        <dt class="col-sm-4">Observação Interna</dt>
                        <dd class="col-sm-8">@Model.ObservacaoInterna</dd>
                    }
                </dl>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Arquivos Anexados</h5>
            </div>
            <div class="card-body">
                @if (!Model.Arquivos.Any())
                {
                    <p class="text-muted mb-0">Nenhum arquivo anexado.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var arquivo in Model.Arquivos)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>@arquivo.NomeArquivo</span>
                                <a href="~/@arquivo.CaminhoArquivo" target="_blank" class="btn btn-sm btn-outline-secondary">Visualizar</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Atualizar Pedido</h5>
            </div>
            <div class="card-body">
                <form asp-controller="AdminPedidos" asp-action="Atualizar" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="StatusEdicao" class="form-label"></label>
                        <select asp-for="StatusEdicao" class="form-select" asp-items="Html.GetEnumSelectList<StatusPedido>()"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ValorPagoEdicao" class="form-label"></label>
                        <input asp-for="ValorPagoEdicao" class="form-control" type="number" step="0.01" min="0" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ObservacaoInternaEdicao" class="form-label"></label>
                        <textarea asp-for="ObservacaoInternaEdicao" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Finalizar" class="form-check-input" type="checkbox" />
                        <label asp-for="Finalizar" class="form-check-label">Finalizar pedido</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Salvar Alterações</button>
                </form>
            </div>
        </div>

        <a asp-controller="AdminPedidos" asp-action="Index" class="btn btn-link mt-3 px-0">&larr; Voltar para listagem</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
